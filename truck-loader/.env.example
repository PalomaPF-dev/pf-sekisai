# ── 環境変数テンプレート ───────────────────────────────────────────────
# 実際の値は .env.local（gitignore 済み）に設定してください。
# 本番（Vercel）はプロジェクトの Environment Variables に設定します。

# ── 必須 ──────────────────────────────────────────────────────────────

# Neon PostgreSQL 接続文字列
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# NextAuth セッション署名用シークレット（`openssl rand -base64 32` などで生成）
# ネイティブのトークン認証もこの鍵で署名します。
NEXTAUTH_SECRET="ここにランダムな長い文字列"
NEXTAUTH_URL="http://localhost:3000"

# ── サブスク（RevenueCat）──────────────────────────────────────────────
# RevenueCat の Apple App 公開SDKキー（ネイティブビルドに埋め込む。公開可・購入のみ可能）
# RevenueCat ダッシュボード → Project → API keys → "App specific keys"(Apple) の public key
NEXT_PUBLIC_RC_IOS_API_KEY="appl_xxxxxxxxxxxxxxxx"
# RevenueCat Webhook の Authorization ヘッダ（任意の長い文字列。RCダッシュボードと一致させる）
# サーバ(Vercel)の環境変数にのみ設定。クライアントには出さない。
RC_WEBHOOK_AUTH="ここにランダムな長い文字列"
